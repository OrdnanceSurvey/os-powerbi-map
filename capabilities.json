{
    "dataRoles": [
        {
            "name": "point_geocodes",
            "displayName": "Points: Postcodes or UPRNs",
            "description": "Postcodes or UPRNs to geocode and display as points. Exclusive with X/Y coordinate buckets.",
            "kind": "Grouping",
            "preferredTypes": [{"geography": {"postalCode": true}},{"integer": true}, {"numeric": true}]
        },
        {
            "name": "easting",
            "displayName": "Points: X (Easting or Longitude)",
            "description": "X coordinates of geo-located point data (easting in BNG, or longitude in decimal degrees). Exclusive with geocodes bucket.",
            "kind": "Grouping",
            "requiredTypes": [
                {"numeric": true},
                {"integer": true},
                {"geography": {"longitude": true}}
            ]
        },
        {
            "name": "northing",
            "displayName": "Points: Y (Northing or Latitude)",
            "description": "Y coordinate of geo-located point data (northing in BNG, or latitude in decimal degrees). Exclusive with geocodes bucket.",
            "kind": "Grouping",
            "requiredTypes": [
                {"numeric": true},
                {"integer": true},
                {"geography": {"latitude": true}}
            ]
        },
        {
            "name": "point_colour",
            "displayName": "Points: Colour",
            "description": "Values to colour point markers. Can be RGB strings such as '#453C90', or numeric, or text, or not provided. If numeric, the colour will be scaled betwen the values set on the formatting / settings pane. If text the values will be displayed using a different colour for each unique value up to a maximum of 12 unique values.",
            "kind": "GroupingOrMeasure",
            "preferredTypes": [{"text": true}, {"numeric": true}]
        },
        {
            "name": "point_size",
            "kind": "GroupingOrMeasure",
            "displayName": "Points: Size",
            "description": "Numeric values to control marker size (radius). Will be scaled to the maximum / minimum values specified in the formatting / settings pane.",
            "requiredTypes": [
              {
                "numeric": true
              },
              {
                "integer": true
              }
            ]
        },
        {
            "name": "point_popup_text",
            "displayName": "Points: Pop-ups",
            "description": "Field(s) containing information to show in popups on marker points layer. You can add multiple fields, and reorder the fields to change order in the popups.",
            "kind": "GroupingOrMeasure",
            "preferredTypes": [
                {"numeric": true},
                {"integer": true},
                {"text": true}
            ]
        },
        {
            "name": "feature_geometry",
            "displayName": "Features Layer: WKT or GeoJSON Geometries",
            "description": "WKT or GeoJSON geometries to add to the map from your Power BI data model. These can be WKT geometries, standalone GeoJSON geometries, or full GeoJSON features. If they are features then their properties will be added to the popups unless fields from the data model are chosen below. Objects must have a CRS defined if they are not WGS84/lat-lon coordinates.",
            "kind": "Grouping",
            "preferredTypes": [{"text": true}]
        },
        {
            "name": "gss_code",
            "displayName": "Features Layer: GSS codes for geocoding ONS boundaries",
            "description": "GSS polygon identifiers for geocoding data to polygons for choropleth mapping, for example LSOA or Ward boundaries. See the documentation for a list of supported code types.",
            "kind": "Grouping",
            "preferredTypes": [{"text": true}]
        },
        {
            "name": "geojson_reference",
            "displayName": "Features Layer: Linking identifier to match in uploaded geometries",
            "description": "Identifiers to match to features in the uploaded spatial data (upload data on the Format Visual tab and choose the column in the dropdown there which matches the data you add to this field)",
            "kind": "Grouping",
            "preferredTypes": [{"text": true}]
        },
        {
            "name": "polygon_colour",
            "displayName": "Features Layer: Colour",
            "description": "Values to colour features in the features layer. Can be RGB strings such as '#453C90', or numeric, or text, or not provided. If numeric, the colour will be scaled betwen the values set on the formatting / settings pane. If text the values will be displayed using a different colour for each unique value up to a maximum of 12 unique values.",
            "kind": "GroupingOrMeasure",
            "preferredTypes": [{"text": true}, {"numeric": true}]
        },
        {
            "name": "polygon_popup_text",
            "displayName": "Features Layer: Pop-ups",
            "description": "Field(s) containing text to show in popups on WKT/GeoJSON/GSS features. If not set then geojson properties will be used if present. You can add multiple fields, and reorder the fields to change order in the popups." ,
            "kind": "GroupingOrMeasure" ,
            "preferredTypes": [{"text": true}]
        }
    ],
    "dataViewMappings": [
        {
            "table":{
                "rows": {
                    "select": [
                        {
                            "for": {"in": "easting"}
                        },
                        {
                            "for": {"in": "northing"}
