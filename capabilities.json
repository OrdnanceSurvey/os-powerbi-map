                        },
                        {
                            "for": {"in" : "polygon_colour"}
                        },
                        {
                            "for": {"in": "polygon_popup_text"}
                        }
                    ],
                    "dataReductionAlgorithm": {
                        "top": {
                            "count": 30000
                        }
                    }
                },
                "rowCount": {"supported": {"max": 1000000}}
            },
