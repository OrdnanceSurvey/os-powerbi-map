@startuml
class OSMapsDataviewConverter {
    +convert(options: VisualUpdateOptions): OSMapsParsedTable
    -parse_to_object(options: VisualUpdateOptions): OSMapsParsedTable
}

class OSMapsGeoJSONBuilder {
    +buildPointSet(viewModel: OSMapsParsedTable, cartoSettings: LayerCartoSettings, signal: AbortSignal): Promise<BuildResult>
    +buildGeometriedFeatures(viewmodel: OSMapsParsedTable, settings: ParsedCardSettingsWrapper, signal: AbortSignal, updateid: string): Promise<BuildResult>
    +reindexUserDataGeocoder(joinField: string): void
    -initializePolygonGeocoder(): Promise<void>
    -initializePointGeocoder(): void
    -initializeUserDataGeocoder(joinField: string): void
    -buildGeocodeLogRecord(geocodeMetrics: GeocodeMetrics): LogRecord
}

note right of OSMapsGeoJSONBuilder
  BuildResult = {
    featurecoll: OSMapsCartographicFeatureCollection,
    isAborted: boolean,
    logRecords: LogRecord[]
  }
end note

class PointGeocoder {
    +geocode(value: string): Promise<any>
}

class PolygonGeocoder {
    +geocode(value: string): Promise<any>
}

class UserDataGeocoder {
    +geocode(value: string): any
    +reindex(joinField: string): void
}

class GeocodeMetrics {
    +addResult(result: any): void
    +getSummary(): any
}

OSMapsGeoJSONBuilder --> PointGeocoder
OSMapsGeoJSONBuilder --> PolygonGeocoder
OSMapsGeoJSONBuilder --> UserDataGeocoder
OSMapsGeoJSONBuilder --> GeocodeMetrics
OSMapsDataviewConverter --> OSMapsGeoJSONBuilder
@enduml